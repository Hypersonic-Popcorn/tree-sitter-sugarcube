{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "sugarcube",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "PATTERN",
            "value": "\\n"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "passage"
              },
              {
                "type": "REPEAT",
                "content": {
                  "type": "PATTERN",
                  "value": "\\n"
                }
              }
            ]
          }
        }
      ]
    },
    "passage": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "passage_header"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "passage_body"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "passage_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "::"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "passage_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "tags",
              "content": {
                "type": "SYMBOL",
                "name": "tag_list"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "metadata",
              "content": {
                "type": "SYMBOL",
                "name": "metadata"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n+"
        }
      ]
    },
    "passage_name": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\[{\\n]+"
        }
      }
    },
    "tag_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "tag": {
      "type": "PATTERN",
      "value": "[^\\]\\s]+"
    },
    "metadata": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "PATTERN",
          "value": "[^}]*"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "passage_body": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "_passage_content"
        }
      }
    },
    "_passage_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "script_block"
        },
        {
          "type": "SYMBOL",
          "name": "macro"
        },
        {
          "type": "SYMBOL",
          "name": "end_macro"
        },
        {
          "type": "SYMBOL",
          "name": "sc_comment"
        },
        {
          "type": "SYMBOL",
          "name": "html_comment"
        },
        {
          "type": "SYMBOL",
          "name": "html_tag"
        },
        {
          "type": "SYMBOL",
          "name": "wiki_link"
        },
        {
          "type": "SYMBOL",
          "name": "image_link"
        },
        {
          "type": "SYMBOL",
          "name": "styled_text"
        },
        {
          "type": "SYMBOL",
          "name": "variable"
        },
        {
          "type": "SYMBOL",
          "name": "temp_variable"
        },
        {
          "type": "SYMBOL",
          "name": "naked_expression"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "<"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": ">"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "\\$\\{"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "@"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "html_tag": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "<\\/?[a-zA-Z][^>]*>"
        }
      }
    },
    "macro": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<<"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "macro_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "args",
              "content": {
                "type": "SYMBOL",
                "name": "macro_args"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ">>"
        }
      ]
    },
    "end_macro": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "<</"
            },
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "macro_name"
              }
            },
            {
              "type": "STRING",
              "value": ">>"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "<<"
            },
            {
              "type": "STRING",
              "value": "end"
            },
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "macro_name"
              }
            },
            {
              "type": "STRING",
              "value": ">>"
            }
          ]
        }
      ]
    },
    "script_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<<script>>"
        },
        {
          "type": "FIELD",
          "name": "code",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "_raw_js_body"
                },
                "named": true,
                "value": "raw_content"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "<</script>>"
        }
      ]
    },
    "macro_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z][a-zA-Z0-9_-]*"
    },
    "macro_args": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_macro_arg_token"
      }
    },
    "_macro_arg_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "variable"
        },
        {
          "type": "SYMBOL",
          "name": "temp_variable"
        },
        {
          "type": "SYMBOL",
          "name": "string_literal"
        },
        {
          "type": "SYMBOL",
          "name": "number_literal"
        },
        {
          "type": "SYMBOL",
          "name": "bool_literal"
        },
        {
          "type": "SYMBOL",
          "name": "naked_expression"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "_"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "=>"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "[()]"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "<"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": ">"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "\\$"
            }
          }
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "PREC",
            "value": -1,
            "content": {
              "type": "PATTERN",
              "value": "[^<>\\n'\"$_\\s][^<>\\n'\"$_\\s]*"
            }
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t\\r\\n]+"
        }
      ]
    },
    "variable": {
      "type": "PATTERN",
      "value": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "temp_variable": {
      "type": "PATTERN",
      "value": "\\_[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "styled_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "@@"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "style",
                  "content": {
                    "type": "PATTERN",
                    "value": "[^;@]+"
                  }
                },
                {
                  "type": "STRING",
                  "value": ";"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "PATTERN",
            "value": "[^@]+"
          }
        },
        {
          "type": "STRING",
          "value": "@@"
        }
      ]
    },
    "wiki_link": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "[["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "label",
                  "content": {
                    "type": "SYMBOL",
                    "name": "link_text"
                  }
                },
                {
                  "type": "STRING",
                  "value": "|"
                },
                {
                  "type": "FIELD",
                  "name": "target",
                  "content": {
                    "type": "SYMBOL",
                    "name": "link_text"
                  }
                }
              ]
            },
            {
              "type": "FIELD",
              "name": "target",
              "content": {
                "type": "SYMBOL",
                "name": "link_text"
              }
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "link_text": {
      "type": "PATTERN",
      "value": "[^\\]|]+"
    },
    "image_link": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "[img["
          },
          {
            "type": "FIELD",
            "name": "url",
            "content": {
              "type": "PATTERN",
              "value": "[^\\]]+"
            }
          },
          {
            "type": "STRING",
            "value": "]]"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "["
                  },
                  {
                    "type": "FIELD",
                    "name": "target",
                    "content": {
                      "type": "SYMBOL",
                      "name": "link_text"
                    }
                  },
                  {
                    "type": "STRING",
                    "value": "]"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "string_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "PATTERN",
              "value": "[^'\\\\]*(?:\\\\.[^'\\\\]*)*"
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "`"
            },
            {
              "type": "PATTERN",
              "value": "[^`\\\\]*(?:\\\\.[^`\\\\]*)*"
            },
            {
              "type": "STRING",
              "value": "`"
            }
          ]
        }
      ]
    },
    "number_literal": {
      "type": "PATTERN",
      "value": "-?[0-9]+(\\.[0-9]+)?"
    },
    "bool_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "naked_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<<="
        },
        {
          "type": "FIELD",
          "name": "expression",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "PATTERN",
              "value": "[^>]+"
            },
            "named": true,
            "value": "expression"
          }
        },
        {
          "type": "STRING",
          "value": ">>"
        }
      ]
    },
    "sc_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_sc_comment_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "*/"
        }
      ]
    },
    "html_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<!--"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_raw_html_comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "-->"
        }
      ]
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -2,
        "content": {
          "type": "PATTERN",
          "value": "[^<\\@$_\\n][^<\\@\\n]*"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_raw_js_body"
    },
    {
      "type": "SYMBOL",
      "name": "_raw_html_comment"
    },
    {
      "type": "SYMBOL",
      "name": "_sc_comment_body"
    },
    {
      "type": "SYMBOL",
      "name": "_error_sentinel"
    },
    {
      "type": "SYMBOL",
      "name": "_raw_passage_body"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}